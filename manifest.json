{
  "manifest_version": 3,
  "name": "Payment Reminder Assistant",
  "version": "1.0.0",
  "description": "Send payment reminders via Email & WhatsApp directly from Google Sheets",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "host_permissions": [
    "https://docs.google.com/*",
    "https://sheets.google.com/*"
  ]
}