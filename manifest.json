{
  "manifest_version": 3,
  "name": "Payment Reminder Assistant",
  "version": "1.0.0",
  "description": "Send payment reminders via Email & WhatsApp directly from Google Sheets",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Payment Reminder Assistant"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon2.png",
    "48": "icons/icon2.png",
    "128": "icons/icon2.png"
  },
  "host_permissions": [
    "https://docs.google.com/*",
    "https://sheets.google.com/*"
  ]
}